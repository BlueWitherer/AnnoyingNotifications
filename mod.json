{
    "geode": "5.4.0",
    "gd": {
        "win": "2.2081",
        "android": "2.2081",
        "mac": "2.2081",
        "ios": "2.2081"
    },
    "id": "cheeseworks.notifs",
    "name": "Notification Hell",
    "version": "1.0.0",
    "developers": [
        "Cheeseworks"
    ],
    "description": "Check your notification feed or lose!",
    "links": {
        "source": "https://github.com/Cheeseworks/AnnoyingNotifications",
        "homepage": "https://www.cheeseworks.gay/",
        "community": "https://www.dsc.gg/cheeseworks"
    },
    "tags": [
        "joke",
        "offline",
        "gameplay"
    ],
    "dependencies": {
        "cubicstudios.horriblemenu": {
            "version": ">=1.1.0",
            "required": false
        }
    },
    "resources": {
        "spritesheets": {
            "AN_senders": [
                "resources/*.png"
            ]
        }
    },
    "api": {
        "include": [
            "include/*.h*"
        ]
    },
    "settings": {
        "always-on": {
            "type": "bool",
            "name": "Always On",
            "description": "Keep notifications always on outside of the level.",
            "default": false
        },
        "challenge-mode": {
            "type": "bool",
            "name": "Challenge Mode",
            "description": "Add a notification feed that puts a time limit on how long you have left to actually respond to notifications.",
            "default": true,
            "enable-if": "!always-on",
            "enable-if-description": "Persistent notifications must be disabled to use Challenge Mode."
        }
    },
    "early-load": false
}